<Project Sdk="Dalamud.NET.Sdk/15.0.0">

    <PropertyGroup>
        <LangVersion>preview</LangVersion>
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
        <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
        <ProduceReferenceAssembly>false</ProduceReferenceAssembly>
        <EnableWindowsTargeting>true</EnableWindowsTargeting>
        <Nullable>disable</Nullable>
        <NoWarn>CS1591</NoWarn>
        <AssemblyVersion>1.0.0.4</AssemblyVersion>
      <Use_DalamudPackager>false</Use_DalamudPackager>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="ECommons" Version="3.2.0.11" />
    </ItemGroup>
    <PropertyGroup Condition="'$(GITHUB_ACTIONS)' == ''">
      <DalamudLibPath>$(appdata)\XIVLauncherCN\addon\Hooks\dev</DalamudLibPath>
      <AssemblySearchPaths>$(AssemblySearchPaths);$(DalamudLibPath)</AssemblySearchPaths>
    </PropertyGroup>
</Project>
